apiVersion: argoproj.io/v1alpha1
kind: Application
metadata:
  name: envoy-gateway
  namespace: argocd
spec:
  project: default

  source:
    repoURL: https://gateway.envoyproxy.io/helm
    chart: gateway-helm
    targetRevision: v1.5.4

    helm:
      releaseName: envoy-gateway

  destination:
    server: https://kubernetes.default.svc
    namespace: envoy-gateway-system

  syncPolicy:
    automated:
      prune: true
      selfHeal: true

    syncOptions:
      - CreateNamespace=true